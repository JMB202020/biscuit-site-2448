---
import '../styles/site.css';
const nav = [
  { label: 'Home', href: '/2448' },
  { label: 'Services', href: '/2448/services' },
  { label: 'Salon', href: '/2448/salon' },
  { label: 'Self-Service Wash', href: '/2448/self-service' },
  { label: 'Gallery', href: '/2448/gallery' },
  { label: 'About', href: '/2448/about' },
  { label: 'Contact', href: '/2448/contact' },
];
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>About Me | Dog Gone Clean, Swansea</title>
    <meta name="description" content="About Dog Gone Clean in Swansea. Professional dog groomer trained at Classic Canine Cuts, offering full grooming for all breeds in Swansea." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preload" href="/2448/fonts/nunito-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/2448/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="bg-brand-bg">

    <!-- Preview banner -->
    <div class="bg-brand-accent text-white py-2.5 px-4 text-center text-sm sticky top-0 z-50">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-4">
        <span>Preview redesign for <strong>Dog Gone Clean</strong> by <strong>Biscuit Web</strong></span>
        <a href="https://biscuitweb.co.uk/activate?id=2448&name=Dog%20Gone%20Clean" class="inline-flex items-center px-4 py-1 bg-white text-brand-accent font-bold text-xs rounded-full hover:opacity-80 transition-opacity shrink-0">
          Like it? Activate for &pound;50
        </a>
      </div>
    </div>

    <!-- Header -->
    <header class="bg-white border-b border-border sticky top-10 z-40">
      <div class="mx-auto max-w-7xl px-6 py-4 flex items-center justify-between">
        <a href="/2448" class="font-display font-extrabold text-xl text-brand-accent">Dog Gone Clean 🐾</a>
        <button class="md:hidden p-2 text-ink-soft" onclick="document.getElementById('mobile-nav').classList.toggle('hidden')" aria-label="Open menu">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        </button>
        <nav class="hidden md:flex items-center gap-5">
          {nav.map(n => (
            <a href={n.href} class={`text-sm font-semibold transition-colors ${n.href === '/2448/about' ? 'text-brand-accent' : 'text-ink-soft hover:text-brand-accent'}`}>{n.label}</a>
          ))}
          <a href="tel:+447837280709" class="inline-flex items-center px-5 py-2 bg-brand-accent text-white font-display font-bold text-sm rounded hover:opacity-90 transition-opacity">
            07837 280 709
          </a>
        </nav>
      </div>
      <div id="mobile-nav" class="hidden md:hidden border-t border-border bg-white px-6 pb-4">
        {nav.map(n => (
          <a href={n.href} class="block py-2.5 text-sm font-semibold text-ink-soft hover:text-brand-accent border-b border-border last:border-0">{n.label}</a>
        ))}
        <a href="tel:+447837280709" class="mt-3 block text-center px-5 py-3 bg-brand-accent text-white font-display font-bold text-sm rounded">
          Call: 07837 280 709
        </a>
      </div>
    </header>

    <!-- Page hero -->
    <section class="relative overflow-hidden min-h-[45vh] sm:min-h-[55vh] bg-ink flex items-end">
      <img src="/2448/images/p1030032.jpg" alt="Dog Gone Clean grooming salon in Swansea" class="absolute inset-0 w-full h-full object-cover" fetchpriority="high" />
      <div class="absolute inset-0 bg-black/70"></div>
      <div class="relative z-10 mx-auto max-w-4xl px-6 pb-12 pt-32 text-white w-full">
        <div class="inline-flex items-center gap-1.5 bg-white/15 text-white text-sm font-semibold px-4 py-1.5 rounded-full mb-4">
          📍 Swansea
        </div>
        <h1 class="text-3xl sm:text-5xl font-display font-extrabold text-white mb-3">About Me</h1>
        <p class="text-white/85 text-lg max-w-xl">Professional dog groomer based in Swansea, caring for dogs of all breeds and sizes.</p>
      </div>
    </section>

    <!-- About content -->
    <section class="py-16 sm:py-24 bg-white">
      <div class="mx-auto max-w-4xl px-6">
        <div class="prose max-w-none">
          <p class="text-ink-soft text-lg leading-relaxed mb-5">
            Dog Gone Clean is my grooming salon, based at 74 Bon-Y-Maen Road in Swansea. I set it up because I love dogs and I wanted to give them a grooming experience that's calm, professional and tailored to each individual animal.
          </p>
          <p class="text-ink-soft leading-relaxed mb-5">
            I trained at <strong class="text-ink"><a href="http://www.doggroomingschool.co.uk/" target="_blank" rel="noopener noreferrer" class="text-brand-accent hover:underline">Classic Canine Cuts Dog Grooming School</a></strong>, where I learned breed standards, different coat types, scissoring and clipping techniques, and how to handle dogs who might find the whole experience a bit daunting. Good training matters, and I wanted to do things properly from the start.
          </p>
          <p class="text-ink-soft leading-relaxed mb-5">
            Since then, I've worked with hundreds of dogs across every breed imaginable. Tiny Yorkies. Giant Akitas and Alaskan Malamutes. Elderly dogs who need gentle handling. Nervous puppies who've never been on a grooming table before. You get a feel for what each dog needs, and that's what I focus on.
          </p>
          <p class="text-ink-soft leading-relaxed mb-5">
            The <a href="/2448/gallery" class="text-brand-accent hover:underline font-semibold">gallery</a> shows the variety of dogs I've worked with over the years. Before and after, puppies, big breeds, everything. I'm proud of the work and I think the photos speak for themselves.
          </p>
          <p class="text-ink-soft leading-relaxed mb-8">
            If you're not sure whether your dog is suitable, or if your dog has any health conditions or sensitivities, just give me a ring. I'm always happy to have a chat before you book.
          </p>

          <div class="bg-brand-bg rounded-2xl p-6 border border-border mt-8">
            <h2 class="text-lg font-display font-extrabold text-ink mb-4">Get in touch</h2>
            <ul class="space-y-3 text-ink-soft text-sm">
              <li class="flex items-center gap-3">
                <span class="text-brand-accent font-semibold">📞</span>
                <a href="tel:+447837280709" class="hover:text-brand-accent transition-colors font-semibold">07837 280 709</a>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-brand-accent font-semibold mt-0.5">📍</span>
                <span>74 Bon-Y-Maen Rd, Swansea</span>
              </li>
              <li class="flex items-center gap-3">
                <span class="text-brand-accent font-semibold">👍</span>
                <a href="http://en-gb.facebook.com/pages/Dog-Gone-Clean/245372945482676" target="_blank" rel="noopener noreferrer" class="hover:text-brand-accent transition-colors">Facebook Page</a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-14 bg-brand-accent text-white text-center">
      <div class="mx-auto max-w-2xl px-6">
        <h2 class="text-2xl font-display font-extrabold text-white mb-4">Ready to book?</h2>
        <p class="text-white/85 mb-6">Give me a call to discuss your dog and check availability.</p>
        <a href="tel:+447837280709" class="inline-flex items-center gap-2 px-8 py-3.5 bg-white text-brand-accent font-display font-bold rounded hover:opacity-90 transition-opacity">
          📞 07837 280 709
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-ink text-white py-12">
      <div class="mx-auto max-w-7xl px-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-8">
          <div>
            <div class="font-display font-extrabold text-lg text-white mb-3">Dog Gone Clean 🐾</div>
            <p class="text-white/60 text-sm leading-relaxed">Professional dog grooming for all breeds, large or small. Based in Swansea.</p>
          </div>
          <div>
            <div class="font-display font-bold text-sm text-white/80 uppercase tracking-widest mb-3">Pages</div>
            <ul class="space-y-2">
              {nav.map(n => (
                <li><a href={n.href} class="text-white/60 text-sm hover:text-white transition-colors">{n.label}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <div class="font-display font-bold text-sm text-white/80 uppercase tracking-widest mb-3">Contact</div>
            <ul class="space-y-2 text-white/60 text-sm">
              <li><a href="tel:+447837280709" class="hover:text-white transition-colors">07837 280 709</a></li>
              <li>74 Bon-Y-Maen Rd<br />Swansea</li>
            </ul>
          </div>
          <div>
            <div class="font-display font-bold text-sm text-white/80 uppercase tracking-widest mb-3">Follow Us</div>
            <a href="http://en-gb.facebook.com/pages/Dog-Gone-Clean/245372945482676" target="_blank" rel="noopener noreferrer" class="text-white/60 text-sm hover:text-white transition-colors">
              Facebook Page &rarr;
            </a>
          </div>
        </div>
        <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-white/40 text-xs">
          <span>&copy; 2024 Dog Gone Clean. All rights reserved.</span>
          <span>This is a sample site built by <a href="/" class="hover:text-white/70 transition-colors">Biscuit Web</a> to showcase our work.</span>
        </div>
      </div>
    </footer>

  </body>
</html>
