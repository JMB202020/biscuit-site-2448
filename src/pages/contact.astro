---
import '../styles/site.css';
const nav = [
  { label: 'Home', href: '/2448' },
  { label: 'Services', href: '/2448/services' },
  { label: 'Salon', href: '/2448/salon' },
  { label: 'Self-Service Wash', href: '/2448/self-service' },
  { label: 'Gallery', href: '/2448/gallery' },
  { label: 'About', href: '/2448/about' },
  { label: 'Contact', href: '/2448/contact' },
];
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Contact | Dog Gone Clean, Swansea</title>
    <meta name="description" content="Get in touch with Dog Gone Clean in Swansea. Call 07837 280 709 or visit us at 74 Bon-Y-Maen Road, Swansea." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preload" href="/2448/fonts/nunito-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/2448/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="bg-brand-bg">

    <!-- Preview banner -->
    <div class="bg-brand-accent text-white py-2.5 px-4 text-center text-sm sticky top-0 z-50">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-4">
        <span>Preview redesign for <strong>Dog Gone Clean</strong> by <strong>Biscuit Web</strong></span>
        <a href="https://biscuitweb.co.uk/activate?id=2448&name=Dog%20Gone%20Clean" class="inline-flex items-center px-4 py-1 bg-white text-brand-accent font-bold text-xs rounded-full hover:opacity-80 transition-opacity shrink-0">
          Like it? Activate for &pound;50
        </a>
      </div>
    </div>

    <!-- Header -->
    <header class="bg-white border-b border-border sticky top-10 z-40">
      <div class="mx-auto max-w-7xl px-6 py-4 flex items-center justify-between">
        <a href="/2448" class="font-display font-extrabold text-xl text-brand-accent">Dog Gone Clean 🐾</a>
        <button class="md:hidden p-2 text-ink-soft" onclick="document.getElementById('mobile-nav').classList.toggle('hidden')" aria-label="Open menu">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        </button>
        <nav class="hidden md:flex items-center gap-5">
          {nav.map(n => (
            <a href={n.href} class={`text-sm font-semibold transition-colors ${n.href === '/2448/contact' ? 'text-brand-accent' : 'text-ink-soft hover:text-brand-accent'}`}>{n.label}</a>
          ))}
          <a href="tel:+447837280709" class="inline-flex items-center px-5 py-2 bg-brand-accent text-white font-display font-bold text-sm rounded hover:opacity-90 transition-opacity">
            07837 280 709
          </a>
        </nav>
      </div>
      <div id="mobile-nav" class="hidden md:hidden border-t border-border bg-white px-6 pb-4">
        {nav.map(n => (
          <a href={n.href} class="block py-2.5 text-sm font-semibold text-ink-soft hover:text-brand-accent border-b border-border last:border-0">{n.label}</a>
        ))}
        <a href="tel:+447837280709" class="mt-3 block text-center px-5 py-3 bg-brand-accent text-white font-display font-bold text-sm rounded">
          Call: 07837 280 709
        </a>
      </div>
    </header>

    <!-- Page header -->
    <section class="py-14 sm:py-20 bg-brand-accent text-white text-center">
      <div class="mx-auto max-w-3xl px-6">
        <div class="inline-flex items-center gap-1.5 bg-white/15 text-white text-sm font-semibold px-4 py-1.5 rounded-full mb-4">
          📍 Swansea
        </div>
        <h1 class="text-3xl sm:text-5xl font-display font-extrabold text-white mb-4">Get in Touch</h1>
        <p class="text-white/85 text-lg max-w-xl mx-auto">The best way to book is to give us a ring. We'll sort you out with an appointment and answer any questions about your dog.</p>
      </div>
    </section>

    <!-- Contact info + hero image -->
    <section class="py-16 sm:py-20 bg-white">
      <div class="mx-auto max-w-6xl px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
          <!-- Contact details -->
          <div>
            <h2 class="text-2xl font-display font-extrabold text-ink mb-6">Contact Details</h2>
            <ul class="space-y-6">
              <li class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-brand-pink-light flex items-center justify-center text-xl shrink-0">📞</div>
                <div>
                  <div class="font-display font-bold text-ink text-sm mb-0.5">Phone</div>
                  <a href="tel:+447837280709" class="text-brand-accent font-semibold text-lg hover:underline">07837 280 709</a>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-brand-pink-light flex items-center justify-center text-xl shrink-0">📍</div>
                <div>
                  <div class="font-display font-bold text-ink text-sm mb-0.5">Address</div>
                  <address class="not-italic text-ink-soft">
                    74 Bon-Y-Maen Rd<br />
                    Swansea
                  </address>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-brand-pink-light flex items-center justify-center text-xl shrink-0">👍</div>
                <div>
                  <div class="font-display font-bold text-ink text-sm mb-0.5">Facebook</div>
                  <a href="http://en-gb.facebook.com/pages/Dog-Gone-Clean/245372945482676" target="_blank" rel="noopener noreferrer" class="text-brand-accent hover:underline">Dog Gone Clean on Facebook</a>
                </div>
              </li>
            </ul>

            <div class="mt-8 bg-brand-bg rounded-2xl p-6 border border-border">
              <h3 class="font-display font-bold text-ink mb-2">Collection &amp; Delivery</h3>
              <p class="text-ink-soft text-sm leading-relaxed">We offer a collection and delivery service for customers in the Swansea area. Call us to discuss whether we can come to you.</p>
            </div>
          </div>

          <!-- Image -->
          <div class="overflow-hidden rounded-2xl aspect-video">
            <img src="/2448/images/laptop-20dog-20short.jpg" alt="Dog Gone Clean" loading="lazy" class="w-full h-full object-cover" width="1080" height="596" />
          </div>
        </div>
      </div>
    </section>

    <!-- Map -->
    <section class="bg-cream-dark py-12">
      <div class="mx-auto max-w-5xl px-6">
        <h2 class="text-xl font-display font-extrabold text-ink mb-6">Find Us</h2>
        <div class="rounded-2xl overflow-hidden border border-border shadow-md" style="height: 400px;">
          <iframe
            src="https://maps.google.co.uk/maps?f=q&source=s_q&hl=en&geocode=&q=dog+gone+clean&aq=&sll=53.800651,-4.064941&sspn=22.96309,53.569336&ie=UTF8&hq=dog+gone+clean&hnear=&ll=51.657436,-3.913536&spn=0.102232,0.219727&z=12&iwloc=A&output=embed"
            width="100%"
            height="100%"
            style="border:0;"
            loading="lazy"
            title="Dog Gone Clean location map"
          ></iframe>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-ink text-white py-12">
      <div class="mx-auto max-w-7xl px-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-8">
          <div>
            <div class="font-display font-extrabold text-lg text-white mb-3">Dog Gone Clean 🐾</div>
            <p class="text-white/60 text-sm leading-relaxed">Professional dog grooming for all breeds, large or small. Based in Swansea.</p>
          </div>
          <div>
            <div class="font-display font-bold text-sm text-white/80 uppercase tracking-widest mb-3">Pages</div>
            <ul class="space-y-2">
              {nav.map(n => (
                <li><a href={n.href} class="text-white/60 text-sm hover:text-white transition-colors">{n.label}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <div class="font-display font-bold text-sm text-white/80 uppercase tracking-widest mb-3">Contact</div>
            <ul class="space-y-2 text-white/60 text-sm">
              <li><a href="tel:+447837280709" class="hover:text-white transition-colors">07837 280 709</a></li>
              <li>74 Bon-Y-Maen Rd<br />Swansea</li>
            </ul>
          </div>
          <div>
            <div class="font-display font-bold text-sm text-white/80 uppercase tracking-widest mb-3">Follow Us</div>
            <a href="http://en-gb.facebook.com/pages/Dog-Gone-Clean/245372945482676" target="_blank" rel="noopener noreferrer" class="text-white/60 text-sm hover:text-white transition-colors">
              Facebook Page &rarr;
            </a>
          </div>
        </div>
        <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-white/40 text-xs">
          <span>&copy; 2024 Dog Gone Clean. All rights reserved.</span>
          <span>This is a sample site built by <a href="/" class="hover:text-white/70 transition-colors">Biscuit Web</a> to showcase our work.</span>
        </div>
      </div>
    </footer>

  </body>
</html>
