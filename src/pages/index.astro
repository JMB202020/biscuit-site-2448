---
import '../styles/site.css';
const nav = [
  { label: 'Home', href: '/2448' },
  { label: 'Services', href: '/2448/services' },
  { label: 'Salon', href: '/2448/salon' },
  { label: 'Self-Service Wash', href: '/2448/self-service' },
  { label: 'Gallery', href: '/2448/gallery' },
  { label: 'About', href: '/2448/about' },
  { label: 'Contact', href: '/2448/contact' },
];
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dog Gone Clean | Professional Dog Grooming in Swansea</title>
    <meta name="description" content="Professional dog grooming services for all breeds, large or small. Dog Gone Clean, Swansea. Collection and delivery available. Self-service dog wash too." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preload" href="/2448/fonts/nunito-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/2448/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="bg-brand-bg">

    <!-- Preview banner -->
    <div class="bg-brand-accent text-white py-2.5 px-4 text-center text-sm sticky top-0 z-50">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-4">
        <span>Preview redesign for <strong>Dog Gone Clean</strong> by <strong>Biscuit Web</strong></span>
        <a href="https://biscuitweb.co.uk/activate?id=2448&name=Dog%20Gone%20Clean" class="inline-flex items-center px-4 py-1 bg-white text-brand-accent font-bold text-xs rounded-full hover:opacity-80 transition-opacity shrink-0">
          Like it? Activate for &pound;50
        </a>
      </div>
    </div>

    <!-- Header -->
    <header class="bg-white border-b border-border sticky top-10 z-40">
      <div class="mx-auto max-w-7xl px-6 py-4 flex items-center justify-between">
        <a href="/2448" class="font-display font-extrabold text-xl text-brand-accent">Dog Gone Clean 🐾</a>
        <button class="md:hidden p-2 text-ink-soft" onclick="document.getElementById('mobile-nav').classList.toggle('hidden')" aria-label="Open menu">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        </button>
        <nav class="hidden md:flex items-center gap-5">
          {nav.map(n => (
            <a href={n.href} class={`text-sm font-semibold transition-colors ${n.href === '/2448' ? 'text-brand-accent' : 'text-ink-soft hover:text-brand-accent'}`}>{n.label}</a>
          ))}
          <a href="tel:+447837280709" class="inline-flex items-center px-5 py-2 bg-brand-accent text-white font-display font-bold text-sm rounded hover:opacity-90 transition-opacity">
            07837 280 709
          </a>
        </nav>
      </div>
      <!-- Mobile nav -->
      <div id="mobile-nav" class="hidden md:hidden border-t border-border bg-white px-6 pb-4">
        {nav.map(n => (
          <a href={n.href} class="block py-2.5 text-sm font-semibold text-ink-soft hover:text-brand-accent border-b border-border last:border-0">{n.label}</a>
        ))}
        <a href="tel:+447837280709" class="mt-3 block text-center px-5 py-3 bg-brand-accent text-white font-display font-bold text-sm rounded">
          Call: 07837 280 709
        </a>
      </div>
    </header>

    <!-- Hero: gallery mosaic -->
    <section class="relative overflow-hidden min-h-[60vh] sm:min-h-[80vh] bg-ink flex items-center">
      <!-- Mosaic background grid -->
      <div class="absolute inset-0 grid grid-cols-3 sm:grid-cols-4 gap-0.5 opacity-60">
        <div class="overflow-hidden">
          <img src="/2448/images/p1010875-01.jpg" alt="Schnauzer before grooming" class="w-full h-full object-cover" fetchpriority="high" width="800" height="450" />
        </div>
        <div class="overflow-hidden">
          <img src="/2448/images/p10108791.jpg" alt="Schnauzer after grooming" class="w-full h-full object-cover" fetchpriority="high" width="800" height="450" />
        </div>
        <div class="overflow-hidden">
          <img src="/2448/images/p1020754.jpg" alt="Labradoodle showing off after groom" class="w-full h-full object-cover" fetchpriority="high" width="800" height="450" />
        </div>
        <div class="overflow-hidden hidden sm:block">
          <img src="/2448/images/p1070206.jpg" alt="Bichon Frise after grooming" class="w-full h-full object-cover" fetchpriority="high" width="800" height="450" />
        </div>
        <div class="overflow-hidden">
          <img src="/2448/images/p1060765.jpg" alt="Cocker Spaniels after grooming" class="w-full h-full object-cover" fetchpriority="high" width="800" height="450" />
        </div>
        <div class="overflow-hidden">
          <img src="/2448/images/p1020805.jpg" alt="Miniature poodle after first groom" class="w-full h-full object-cover" fetchpriority="high" width="800" height="450" />
        </div>
        <div class="overflow-hidden hidden sm:block">
          <img src="/2448/images/p1040630.jpg" alt="Yorkshire Terriers after grooming" class="w-full h-full object-cover" width="800" height="450" />
        </div>
        <div class="overflow-hidden">
          <img src="/2448/images/p1050257.jpg" alt="Bichon Frise after grooming" class="w-full h-full object-cover" width="800" height="450" />
        </div>
      </div>
      <!-- Dark overlay for text contrast -->
      <div class="absolute inset-0 bg-black/70"></div>
      <!-- Hero content -->
      <div class="relative z-10 mx-auto max-w-4xl px-6 py-20 text-center text-white">
        <div class="inline-flex items-center gap-1.5 bg-white/15 backdrop-blur-sm text-white text-sm font-semibold px-4 py-1.5 rounded-full mb-6">
          📍 Swansea
        </div>
        <h1 class="text-3xl sm:text-5xl lg:text-6xl font-display font-extrabold text-white mb-6 leading-tight">
          Professional Dog Grooming<br class="hidden sm:block" /> in Swansea
        </h1>
        <p class="text-lg sm:text-xl text-white/90 max-w-2xl mx-auto mb-8">
          Dog Gone Clean offers professional grooming for all breeds, large or small. From full grooms and puppy first appointments to our self-service dog wash. Collection and delivery available.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="tel:+447837280709" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-brand-accent text-white font-display font-bold text-base rounded hover:opacity-90 transition-opacity">
            📞 Call 07837 280 709
          </a>
          <a href="/2448/gallery" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-white/15 backdrop-blur-sm text-white font-display font-bold text-base rounded border border-white/30 hover:bg-white/25 transition-colors">
            View Gallery
          </a>
        </div>
      </div>
    </section>

    <!-- Services grid -->
    <section class="py-16 sm:py-24 bg-white">
      <div class="mx-auto max-w-7xl px-6">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-display font-extrabold text-ink mb-3">Our Services</h2>
          <p class="text-ink-soft max-w-xl mx-auto">Everything your dog needs, from a quick freshen-up to a full pamper session.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <!-- Full Groom -->
          <div class="bg-brand-bg rounded-2xl p-6 border border-border">
            <div class="text-3xl mb-3">✂️</div>
            <h3 class="text-lg font-display font-extrabold text-ink mb-2">Full Groom</h3>
            <p class="text-ink-soft text-sm leading-relaxed">Bath, dry, clip or scissor to your preferred style, nail trim, ear clean and finishing spritz. We work to breed standard or owner preference.</p>
          </div>
          <!-- Bath &amp; Brush -->
          <div class="bg-brand-bg rounded-2xl p-6 border border-border">
            <div class="text-3xl mb-3">🛁</div>
            <h3 class="text-lg font-display font-extrabold text-ink mb-2">Bath &amp; Brush</h3>
            <p class="text-ink-soft text-sm leading-relaxed">A thorough shampoo, blow-dry and brush-out to keep coats fresh between full grooms. Perfect for dogs that need regular coat maintenance.</p>
          </div>
          <!-- Puppy First Groom -->
          <div class="bg-brand-purple-light rounded-2xl p-6 border border-brand-purple/20">
            <div class="text-3xl mb-3">🐶</div>
            <h3 class="text-lg font-display font-extrabold text-ink mb-2">Puppy First Groom</h3>
            <p class="text-ink-soft text-sm leading-relaxed">A gentle introduction to the salon for pups. We take our time to make it a calm, positive experience so they grow up enjoying their grooms.</p>
          </div>
          <!-- Self-Service Dog Wash -->
          <div class="bg-brand-pink-light rounded-2xl p-6 border border-brand-accent/20">
            <div class="text-3xl mb-3">🚿</div>
            <h3 class="text-lg font-display font-extrabold text-ink mb-2">Self-Service Dog Wash</h3>
            <p class="text-ink-soft text-sm leading-relaxed">Use our professional walk-in bath, shampoo, conditioner and drying facilities. Great for in-between grooms or dogs that you prefer to wash yourself.</p>
            <a href="/2448/self-service" class="inline-block mt-3 text-brand-accent text-sm font-semibold hover:underline">Find out more &rarr;</a>
          </div>
          <!-- Collection &amp; Delivery -->
          <div class="bg-brand-bg rounded-2xl p-6 border border-border">
            <div class="text-3xl mb-3">🚗</div>
            <h3 class="text-lg font-display font-extrabold text-ink mb-2">Collection &amp; Delivery</h3>
            <p class="text-ink-soft text-sm leading-relaxed">Can't make it to us? We offer a collection and delivery service. Call us to discuss availability and your location in the Swansea area.</p>
          </div>
          <!-- Nail Trim -->
          <div class="bg-brand-bg rounded-2xl p-6 border border-border">
            <div class="text-3xl mb-3">💅</div>
            <h3 class="text-lg font-display font-extrabold text-ink mb-2">Nail Trim &amp; Ear Clean</h3>
            <p class="text-ink-soft text-sm leading-relaxed">Quick, calm nail trims and ear cleaning for dogs that just need the basics. A good option for older dogs who find a full salon visit tiring.</p>
          </div>
        </div>
        <div class="text-center mt-8">
          <a href="/2448/services" class="inline-flex items-center gap-2 px-7 py-3 bg-brand-accent text-white font-display font-bold text-sm rounded hover:opacity-90 transition-opacity">
            See Full Service List &amp; Prices
          </a>
        </div>
      </div>
    </section>

    <!-- Gallery showcase: before/after -->
    <section class="py-16 sm:py-24 bg-cream-dark">
      <div class="mx-auto max-w-7xl px-6">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-display font-extrabold text-ink mb-3">Before &amp; After</h2>
          <p class="text-ink-soft max-w-xl mx-auto">The proof is in the pooches. Here are a few of our recent transformations.</p>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
          <div class="overflow-hidden rounded-xl aspect-square">
            <img src="/2448/images/p1010875-01.jpg" alt="Schnauzer before grooming" loading="lazy" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" width="800" height="450" />
          </div>
          <div class="overflow-hidden rounded-xl aspect-square">
            <img src="/2448/images/p10108791.jpg" alt="Schnauzer after grooming" loading="lazy" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" width="800" height="450" />
          </div>
          <div class="overflow-hidden rounded-xl aspect-square">
            <img src="/2448/images/p1020864.jpg" alt="5 month old Shih-Tzu pup" loading="lazy" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" width="800" height="450" />
          </div>
          <div class="overflow-hidden rounded-xl aspect-square">
            <img src="/2448/images/p1020879.jpg" alt="Shih-Tzu pup first groom" loading="lazy" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" width="800" height="450" />
          </div>
          <div class="overflow-hidden rounded-xl aspect-square">
            <img src="/2448/images/p1020040.jpg" alt="Cavalier King Charles Spaniels before" loading="lazy" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" width="800" height="450" />
          </div>
          <div class="overflow-hidden rounded-xl aspect-square">
            <img src="/2448/images/p1020045.jpg" alt="Cavalier King Charles Spaniels after" loading="lazy" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" width="800" height="450" />
          </div>
          <div class="overflow-hidden rounded-xl aspect-square">
            <img src="/2448/images/p1020715.jpg" alt="Labradoodle first groom" loading="lazy" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" width="800" height="450" />
          </div>
          <div class="overflow-hidden rounded-xl aspect-square">
            <img src="/2448/images/p1020756.jpg" alt="Labradoodle after first groom" loading="lazy" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" width="800" height="450" />
          </div>
        </div>
        <div class="text-center mt-8">
          <a href="/2448/gallery" class="inline-flex items-center gap-2 px-7 py-3 border-2 border-brand-accent text-brand-accent font-display font-bold text-sm rounded hover:bg-brand-accent hover:text-white transition-colors">
            View Full Gallery
          </a>
        </div>
      </div>
    </section>

    <!-- About section -->
    <section class="py-16 sm:py-24 bg-white">
      <div class="mx-auto max-w-6xl px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div class="overflow-hidden rounded-2xl aspect-video md:aspect-square max-w-sm mx-auto md:max-w-none">
            <img src="/2448/images/p1030032.jpg" alt="Dog Gone Clean grooming salon Swansea" loading="lazy" class="w-full h-full object-cover" width="800" height="450" />
          </div>
          <div>
            <div class="inline-block text-brand-accent font-display font-bold text-sm uppercase tracking-widest mb-3">About Us</div>
            <h2 class="text-3xl sm:text-4xl font-display font-extrabold text-ink mb-5">A groomer who truly loves dogs</h2>
            <p class="text-ink-soft mb-4 leading-relaxed">
              Dog Gone Clean is based in Swansea at 74 Bon-Y-Maen Road. We provide professional grooming for all breeds, from tiny terriers to big Alaskan Malamutes and Saint Bernards. Every dog is treated with patience and care.
            </p>
            <p class="text-ink-soft mb-4 leading-relaxed">
              We trained at Classic Canine Cuts Dog Grooming School and have built up years of hands-on experience working with every coat type and temperament. Whether your dog is a nervous first-timer or an old hand at salon visits, we'll make them feel comfortable.
            </p>
            <p class="text-ink-soft mb-6 leading-relaxed">
              We handle large breeds every bit as confidently as small ones, and we're happy to discuss any special requirements your dog might have. Collection and delivery is also available for those who can't easily get to us.
            </p>
            <a href="/2448/about" class="inline-flex items-center gap-2 text-brand-accent font-display font-bold hover:underline">
              Read more about us &rarr;
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-brand-accent text-white text-center">
      <div class="mx-auto max-w-3xl px-6">
        <h2 class="text-3xl sm:text-4xl font-display font-extrabold text-white mb-4">Ready to book?</h2>
        <p class="text-white/85 text-lg mb-8 max-w-xl mx-auto">Give us a ring to check availability and get your dog booked in. We're based at 74 Bon-Y-Maen Road, Swansea.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="tel:+447837280709" class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-white text-brand-accent font-display font-bold rounded hover:opacity-90 transition-opacity">
            📞 07837 280 709
          </a>
          <a href="/2448/contact" class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-white/15 text-white font-display font-bold rounded border border-white/30 hover:bg-white/25 transition-colors">
            Find Us
          </a>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-ink text-white py-12">
      <div class="mx-auto max-w-7xl px-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-8">
          <div>
            <div class="font-display font-extrabold text-lg text-white mb-3">Dog Gone Clean 🐾</div>
            <p class="text-white/60 text-sm leading-relaxed">Professional dog grooming for all breeds, large or small. Based in Swansea.</p>
          </div>
          <div>
            <div class="font-display font-bold text-sm text-white/80 uppercase tracking-widest mb-3">Pages</div>
            <ul class="space-y-2">
              {nav.map(n => (
                <li><a href={n.href} class="text-white/60 text-sm hover:text-white transition-colors">{n.label}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <div class="font-display font-bold text-sm text-white/80 uppercase tracking-widest mb-3">Contact</div>
            <ul class="space-y-2 text-white/60 text-sm">
              <li><a href="tel:+447837280709" class="hover:text-white transition-colors">07837 280 709</a></li>
              <li>74 Bon-Y-Maen Rd<br />Swansea</li>
            </ul>
          </div>
          <div>
            <div class="font-display font-bold text-sm text-white/80 uppercase tracking-widest mb-3">Follow Us</div>
            <a href="http://en-gb.facebook.com/pages/Dog-Gone-Clean/245372945482676" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-white/60 text-sm hover:text-white transition-colors">
              Facebook Page &rarr;
            </a>
          </div>
        </div>
        <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-white/40 text-xs">
          <span>&copy; 2024 Dog Gone Clean. All rights reserved.</span>
          <span>This is a sample site built by <a href="/" class="hover:text-white/70 transition-colors">Biscuit Web</a> to showcase our work.</span>
        </div>
      </div>
    </footer>

  </body>
</html>
